APP_NAME="QATTH Career API"
APP_ENV=local
LEGACY_API_ENABLED=false
APP_VERSION=1.0.0-draft
LOG_LEVEL=INFO
API_V1_PREFIX=/v1
PUBLIC_API_ORIGIN=http://localhost:8000
REQUEST_TIMEOUT_SECONDS=30
CORS_ORIGINS='["http://localhost:3000","http://localhost:8501"]'

DATABASE_URL=postgresql+psycopg://qatth:qatth@localhost:5432/qatth
DATABASE_POOL_SIZE=10
DATABASE_POOL_OVERFLOW=10
AUTO_CREATE_TABLES=false

REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=qatth:local
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_AI_REQUESTS_PER_MINUTE=30
TRUSTED_PROXY_CIDRS='[]'
IDEMPOTENCY_TTL_SECONDS=86400

# Local supports local or MinIO. Production requires r2.
STORAGE_BACKEND=local
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=qatthminio
MINIO_SECRET_KEY=qatthminiosecret
MINIO_BUCKET=qatth-assets
MINIO_SECURE=false
R2_ENDPOINT_URL=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
SIGNED_URL_TTL_SECONDS=300
PRIVACY_EXPORT_TTL_HOURS=24
PRIVACY_EXPORT_MAX_BYTES=200000000
# URL-safe base64 encoded 32-byte key. Required outside local/development/test.
PRIVACY_EXPORT_ENCRYPTION_KEY=
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=10

OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_REQUIRED_CLAIMS='["sub"]'

OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_CV_MODEL=gpt-5.6
OPENAI_EVALUATION_MODEL=gpt-5.6
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_SEARCH_MODEL=gpt-5.6
OPENAI_TIMEOUT_SECONDS=60
OPENAI_DAILY_BUDGET_MINOR=500000

GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_SESSION_LIMIT=20
GEMINI_LIVE_SETUP_TIMEOUT_SECONDS=15
GEMINI_LIVE_IDLE_TIMEOUT_SECONDS=60
GEMINI_LIVE_RECONNECT_WINDOW_SECONDS=300
GEMINI_LIVE_LEASE_SECONDS=90
GEMINI_LIVE_AUDIO_CHUNK_MAX_BYTES=65536

PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_SUCCESS_URL_ALLOWLIST='[]'
PAYMENT_PADDLE_API_BASE_URL=https://sandbox-api.paddle.com
PAYMENT_PADDLE_PRICE_IDS='{}'
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=5
PAYMENT_HTTP_TIMEOUT_SECONDS=10

JOB_SEARCH_PROVIDER=openai_web_search
JOB_SEARCH_DEFAULT_LOCATION=Vietnam
JOB_SEARCH_COUNTRY_CODE=VN
JOB_SEARCH_ALLOWED_DOMAINS='[]'
JOB_SEARCH_BLOCKED_DOMAINS='[]'
JOB_SEARCH_LIVE_EXTERNAL_ACCESS=true

OTEL_ENABLED=false
OTEL_SERVICE_NAME=qatth-api
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true

UPLOAD_DIR=data/uploads
GENERATED_DIR=data/generated

# OIDC is mandatory outside local/development/test environments.

# Product interview processing
OPENAI_INTERVIEW_MODEL=gpt-4.1-mini
INTERVIEW_RUBRIC_VERSION=interview-v1
INTERVIEW_PROMPT_VERSION=interview-v1
INTERVIEW_TOKEN_TTL_SECONDS=60

# Product job discovery and ranking
OPENAI_JOB_SEARCH_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
