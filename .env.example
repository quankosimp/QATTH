APP_NAME="QATTH Career API"
APP_ENV=local
API_V1_PREFIX=/v1

# Local demo works with SQLite by default. Use docker-compose for Postgres + pgvector.
DATABASE_URL=sqlite:///./data/qatth.db
# DATABASE_URL=postgresql+psycopg://qatth:qatth@localhost:5432/qatth
AUTO_CREATE_TABLES=false
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

STORAGE_BACKEND=local
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=qatthminio
MINIO_SECRET_KEY=qatthminiosecret
MINIO_BUCKET=qatth-assets
MINIO_SECURE=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
OTEL_ENABLED=false
PROMETHEUS_ENABLED=true

GEMINI_API_KEY=
GEMINI_CV_MODEL=gemini-3.5-flash
GEMINI_EVALUATION_MODEL=gemini-3.5-flash
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview

JOB_SEARCH_PROVIDER=serpapi_google_jobs
SERPAPI_API_KEY=
JOB_SEARCH_DEFAULT_LOCATION=Vietnam

UPLOAD_DIR=data/uploads
GENERATED_DIR=data/generated
CORS_ORIGINS='["http://localhost:3000","http://localhost:8501"]'
